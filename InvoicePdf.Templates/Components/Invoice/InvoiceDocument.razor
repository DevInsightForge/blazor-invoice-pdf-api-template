@using InvoicePdf.Templates.Models
@using InvoicePdf.Templates.Utilities

<style>
    :root {
        --space: 0.75rem;
        --bg: #eef2f6;
        --panel: #ffffff;
        --ink: #1f2937;
        --muted: #667085;
        --line: #d9e0e7;
        --accent: #334155;
        --accent-soft: #edf2f7;
        --ok: #1d7a4f;
    }

    * {
        box-sizing: border-box;
    }

    .invoice-card {
        width: min(1120px, 100%);
        margin: 0 auto;
        padding: var(--space);
        background: var(--panel);
    }

    .invoice-header {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: var(--space);
        align-items: start;
        margin-bottom: var(--space);
    }`n`n
    .eyebrow {
        display: inline-flex;
        margin: 0 0 calc(var(--space) * 0.55);
        padding: calc(var(--space) * 0.35) calc(var(--space) * 0.8);
        border-radius: 999px;
        background: var(--accent-soft);
        color: var(--accent);
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    h1 {
        margin: 0;
        font-size: clamp(1.25rem, 2.1vw, 1.85rem);
        line-height: 1.15;
        color: var(--ink);
    }

    h2 {
        margin: 0 0 calc(var(--space) * 0.35);
        font-size: 1rem;
        line-height: 1.3;
        color: var(--ink);
    }

    .brand-meta {
        margin: calc(var(--space) * 0.22) 0 0;
        color: var(--muted);
        font-size: 0.9rem;
        line-height: 1.35;
    }

    .invoice-meta {
        margin-top: 0;
        padding: 0;
        display: flex;
        justify-content: flex-end;
        align-items: flex-end;
        align-self: end;
    }

    .meta-grid {
        display: grid;
        row-gap: calc(var(--space) * 0.18);
    }

    .meta-item {
        display: grid;
        grid-template-columns: 14ch max-content;
        column-gap: calc(var(--space) * 0.5);
        align-items: baseline;
        white-space: nowrap;
        line-height: 1.3;
    }

    .meta-label {
        font-size: 0.85rem;
        color: var(--muted);
        position: relative;
    }

    .meta-label::after {
        content: ":";
        position: absolute;
        right: 0;
    }

    .meta-value {
        font-size: 0.92rem;
        color: var(--ink);
        font-weight: 600;
    }

    .address-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: var(--space);
        margin-bottom: var(--space);
    }

    .address-card {
        padding: var(--space);
        border: 1px solid var(--line);
        border-radius: 12px;
        background: #f9fbfc;
    }

    .card-label {
        margin: 0 0 calc(var(--space) * 0.35);
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent);
    }

    .address-card p {
        margin: calc(var(--space) * 0.16) 0;
        color: var(--muted);
        font-size: 0.89rem;
        line-height: 1.35;
    }

    .table-wrap {
        overflow-x: auto;
        border: 1px solid var(--line);
        border-radius: 12px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        min-width: 640px;
    }

    th,
    td {
        text-align: left;
        padding: calc(var(--space) * 0.62) calc(var(--space) * 0.8);
        font-size: 0.87rem;
        border-bottom: 1px solid var(--line);
    }

    th {
        background: #f3f6f9;
        color: #4b5565;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-size: 0.74rem;
    }

    td {
        color: var(--ink);
    }

    tbody tr:last-child td {
        border-bottom: 0;
    }

    .num {
        text-align: right;
        font-variant-numeric: tabular-nums;
    }

    .totals-grid {
        margin-top: var(--space);
        display: grid;
        grid-template-columns: 1fr minmax(280px, 360px);
        gap: var(--space);
        align-items: start;
    }

    .note-card,
    .summary-card {
        border-radius: 12px;
        border: 1px solid var(--line);
        background: #ffffff;
        padding: var(--space);
    }

    .note-card p {
        margin: calc(var(--space) * 0.22) 0;
        color: var(--muted);
        font-size: 0.89rem;
        line-height: 1.35;
    }

    .summary-row,
    .summary-total {
        display: flex;
        justify-content: space-between;
        gap: var(--space);
        align-items: baseline;
        padding: calc(var(--space) * 0.38) 0;
        font-variant-numeric: tabular-nums;
    }

    .summary-row {
        color: #4b5565;
        border-bottom: 1px dashed #d7dde5;
        font-size: 0.9rem;
    }

    .summary-total {
        margin-top: calc(var(--space) * 0.2);
        font-size: 1.02rem;
        color: var(--ok);
        font-weight: 700;
    }

    .invoice-footer {
        margin-top: var(--space);
        padding-top: var(--space);
        border-top: 1px solid var(--line);
    }

    .invoice-footer p {
        margin: calc(var(--space) * 0.2) 0;
        color: var(--muted);
        font-size: 0.84rem;
    }

    @@media print {`n        @@page { size: A4; margin: 12mm; }`n`n        body {
            margin: 0;
            background: #ffffff;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        .invoice-card {
            width: 100%;
            max-width: none;
            margin: 0;
            padding: 0;
        }

        .invoice-header {
            grid-template-columns: 1fr auto;
        }

        .invoice-meta {
            margin-top: 0;
        }

        .meta-label {
            font-size: 0.8rem;
        }

        .meta-value {
            font-size: 0.86rem;
        }

        .address-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .totals-grid {
            grid-template-columns: 1fr minmax(280px, 360px);
        }

        .table-wrap {
            overflow: visible;
        }

        thead {
            display: table-header-group;
        }

        tr {
            break-inside: avoid-page;
            page-break-inside: avoid;
        }

        .address-card,
        .note-card,
        .summary-card,
        .invoice-footer {
            break-inside: avoid-page;
            page-break-inside: avoid;
        }

        .eyebrow,
        h1,
        h2,
        .card-label {
            break-after: avoid-page;
            page-break-after: avoid;
        }
    }
</style>

<article class="invoice-card">
    <InvoiceHeader Company="Model.Company" Invoice="Model.Invoice" Formatter="_formatter" />
    <InvoiceInfoPanel BillTo="Model.BillTo" OrderDetails="Model.OrderDetails" Formatter="_formatter" />
    <InvoiceItemsTable Items="Model.LineItems" Formatter="_formatter" />
    <InvoiceSummarySection
        PaymentReceipt="Model.PaymentReceipt"
        Formatter="_formatter"
        Subtotal="Subtotal"
        Tax="Tax"
        Shipping="Shipping"
        Discount="Discount"
        Total="Total"
        AmountPaid="AmountPaid"
        Balance="Balance"
        TaxRatePercent="Model.Summary.TaxRatePercent" />
    <InvoiceFooter Footer="Model.Footer" Formatter="_formatter" />
</article>

@code {
    [Parameter]
    public required InvoiceDocumentModel Model { get; set; }

    private InvoiceDisplayFormatter _formatter = new("en-US");

    private decimal Subtotal => InvoiceCalculations.GetSubtotal(Model);

    private decimal Tax => InvoiceCalculations.GetTax(Model, Subtotal);

    private decimal Shipping => InvoiceCalculations.GetShipping(Model);

    private decimal Discount => InvoiceCalculations.GetDiscount(Model);

    private decimal Total => InvoiceCalculations.GetTotal(Model, Subtotal, Tax, Shipping, Discount);

    private decimal AmountPaid => InvoiceCalculations.GetAmountPaid(Model, Total);

    private decimal Balance => InvoiceCalculations.GetBalance(Model, Total, AmountPaid);

    protected override void OnParametersSet()
    {
        _formatter = new InvoiceDisplayFormatter(Model.Locale);
    }
}

