@using InvoicePdf.Templates.Models
@using InvoicePdf.Templates.Utilities

<section class="table-wrap">
    <table>
        <thead>
            <tr>
                <th>Item</th>
                <th>Description</th>
                <th class="num">Qty</th>
                <th class="num">Unit</th>
                <th class="num">Amount</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Items)
            {
                <tr>
                    <td>@Formatter.SafeText(item.Id)</td>
                    <td>@Formatter.SafeText(item.Description)</td>
                    <td class="num">@Formatter.FormatNumber(item.Quantity)</td>
                    <td class="num">@Formatter.FormatCurrency(item.UnitPrice)</td>
                    <td class="num">@Formatter.FormatCurrency(InvoiceCalculations.GetLineAmount(item))</td>
                </tr>
            }
        </tbody>
    </table>
</section>

@code {
    [Parameter]
    public required IReadOnlyList<InvoiceLineItemModel> Items { get; set; }

    [Parameter]
    public required InvoiceDisplayFormatter Formatter { get; set; }
}
