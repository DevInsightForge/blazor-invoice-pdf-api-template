@using InvoicePdf.Templates.Models
@using InvoicePdf.Templates.Utilities

<section class="totals-grid">
    <div class="note-card">
        <p class="card-label">@Formatter.SafeText(PaymentReceipt.CardLabel)</p>
        @foreach (var row in PaymentReceipt.Lines)
        {
            <p>@Formatter.SafeText(row.Label): @Formatter.SafeText(row.Value)</p>
        }
    </div>

    <div class="summary-card">
        <div class="summary-row">
            <span>Subtotal</span>
            <strong>@Formatter.FormatCurrency(Subtotal)</strong>
        </div>
        <div class="summary-row">
            <span>Tax (@TaxRateText)</span>
            <strong>@Formatter.FormatCurrency(Tax)</strong>
        </div>
        <div class="summary-row">
            <span>Shipping</span>
            <strong>@Formatter.FormatCurrency(Shipping)</strong>
        </div>
        <div class="summary-row">
            <span>Discount</span>
            <strong>-@Formatter.FormatCurrency(Discount)</strong>
        </div>
        <div class="summary-total">
            <span>Invoice Total</span>
            <strong>@Formatter.FormatCurrency(Total)</strong>
        </div>
        <div class="summary-row">
            <span>Amount Paid</span>
            <strong>@Formatter.FormatCurrency(AmountPaid)</strong>
        </div>
        <div class="summary-row">
            <span>Balance</span>
            <strong>@Formatter.FormatCurrency(Balance)</strong>
        </div>
    </div>
</section>

@code {
    [Parameter]
    public required PaymentReceiptModel PaymentReceipt { get; set; }

    [Parameter]
    public required InvoiceDisplayFormatter Formatter { get; set; }

    [Parameter]
    public decimal Subtotal { get; set; }

    [Parameter]
    public decimal Tax { get; set; }

    [Parameter]
    public decimal Shipping { get; set; }

    [Parameter]
    public decimal Discount { get; set; }

    [Parameter]
    public decimal Total { get; set; }

    [Parameter]
    public decimal AmountPaid { get; set; }

    [Parameter]
    public decimal Balance { get; set; }

    [Parameter]
    public decimal? TaxRatePercent { get; set; }

    private string TaxRateText => TaxRatePercent.HasValue ? $"{Formatter.FormatNumber(TaxRatePercent.Value)}%" : "0%";
}
