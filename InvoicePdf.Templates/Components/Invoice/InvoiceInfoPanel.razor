@using InvoicePdf.Templates.Models
@using InvoicePdf.Templates.Utilities

<section class="info-panel">
    <section>
        <h2 class="panel-title">Bill to</h2>
        <p class="panel-lines">@BuildPartyBlock(BillTo)</p>
    </section>

    <section>
        <h2 class="panel-title">Ship to</h2>
        @if (ShipTo is not null)
        {
            <p class="panel-lines">@BuildPartyBlock(ShipTo)</p>
        }
        else
        {
            <p class="panel-lines">-</p>
        }
    </section>

    <section>
        <h2 class="panel-title">Details</h2>
        <div class="details-lines">
            <div class="details-row"><span class="details-label">Invoice no.</span><span>@Formatter.SafeText(Details.InvoiceNumber)</span></div>
            <div class="details-row"><span class="details-label">Invoice date</span><span>@Formatter.FormatDate(Details.InvoiceDate)</span></div>
            <div class="details-row"><span class="details-label">Terms</span><span>@Formatter.SafeText(Details.Terms)</span></div>
            <div class="details-row"><span class="details-label">Due date</span><span>@Formatter.FormatDate(Details.DueDate)</span></div>
        </div>
    </section>
</section>

@code {
    [Parameter]
    public required PartyInfoModel BillTo { get; set; }

    [Parameter]
    public PartyInfoModel? ShipTo { get; set; }

    [Parameter]
    public required InvoiceDetailsModel Details { get; set; }

    [Parameter]
    public required InvoiceDisplayFormatter Formatter { get; set; }

    private string BuildPartyBlock(PartyInfoModel party)
    {
        return $"{Formatter.SafeText(party.Name)}\n{Formatter.FormatAddress(party.Address)}";
    }
}
