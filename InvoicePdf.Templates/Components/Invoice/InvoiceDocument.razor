@using InvoicePdf.Templates.Models
@using InvoicePdf.Templates.Utilities

<style>
    * { box-sizing: border-box; }
    body { margin: 0; background: #fff; color: #111; font-family: "Segoe UI", "Helvetica Neue", Arial, sans-serif; }
    .invoice-page { width: min(100%, 8.5in); margin: 0 auto; padding: 2.2rem 1.8rem 1.8rem; background: #fff; }
    .invoice-header { display: grid; grid-template-columns: 1.6fr 1fr auto; gap: 1.4rem; align-items: start; margin-bottom: 1.25rem; }
    .logo-box { width: 6.5rem; height: 3.1rem; border: 0.06rem solid #d9d9d9; display: flex; align-items: center; justify-content: center; margin-bottom: 0.7rem; }
    .logo-box img { max-width: 100%; max-height: 100%; object-fit: contain; }
    .company-name { font-size: 1rem; font-weight: 600; margin: 0; }
    .company-lines, .contact-lines { margin: 0.25rem 0 0; line-height: 1.35; font-size: 0.9rem; color: #2d2d2d; white-space: pre-line; }
    .invoice-title { margin: 0; font-size: 2.2rem; line-height: 1; font-weight: 600; letter-spacing: 0.01em; text-align: right; color: #111; white-space: nowrap; }
    .info-panel { background: #f5f5f5; border: 0.06rem solid #e8e8e8; display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1.1rem; padding: 0.95rem 1rem; margin-bottom: 1.15rem; }
    .panel-title { margin: 0 0 0.35rem; font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #555; }
    .panel-lines, .details-lines { margin: 0; line-height: 1.35; font-size: 0.88rem; color: #1f1f1f; white-space: pre-line; }
    .details-row { display: flex; justify-content: space-between; gap: 0.8rem; padding: 0.12rem 0; }
    .details-label { color: #565656; }
    .items-table { width: 100%; border-collapse: collapse; margin-bottom: 1rem; font-size: 0.88rem; }
    .items-table th { text-align: left; padding: 0.52rem 0.5rem; border-bottom: 0.08rem solid #dfdfdf; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.04em; color: #555; font-weight: 600; }
    .items-table td { padding: 0.58rem 0.5rem; border-bottom: 0.06rem solid #ececec; vertical-align: top; }
    .items-table td.right, .items-table th.right { text-align: right; }
    .item-primary { font-weight: 500; color: #141414; }
    .item-secondary { display: block; margin-top: 0.14rem; color: #666; font-size: 0.84rem; line-height: 1.3; white-space: pre-line; }
    .invoice-bottom { display: grid; grid-template-columns: 1fr 19rem; gap: 1.2rem; align-items: start; }
    .message-title { margin: 0 0 0.35rem; font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.05em; color: #555; font-weight: 600; }
    .message-body { margin: 0; font-size: 0.88rem; line-height: 1.45; color: #202020; white-space: pre-line; }
    .totals-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    .totals-table td { padding: 0.25rem 0; }
    .totals-table td:last-child { text-align: right; }
    .total-divider td { border-top: 0.09rem solid #cfcfcf; padding-top: 0.52rem; }
    .total-row td { font-size: 1.18rem; font-weight: 700; color: #111; }
    @@media (max-width: 52rem) {
        .invoice-page { width: 100%; padding: 1.25rem 1rem; }
        .invoice-header { grid-template-columns: 1fr; gap: 0.9rem; }
        .invoice-title { text-align: left; font-size: 1.8rem; }
        .info-panel { grid-template-columns: 1fr; }
        .invoice-bottom { grid-template-columns: 1fr; }
    }
    @@media print {
        @@page { size: auto; margin: 0.45in; }
        body { print-color-adjust: exact; -webkit-print-color-adjust: exact; background: #fff; }
        .invoice-page { width: 100%; margin: 0; padding: 0; }
    }
</style>

<article class="invoice-page">
    <InvoiceHeader Company="Model.Company" Details="Model.Details" Formatter="_formatter" />
    <InvoiceInfoPanel BillTo="Model.BillTo" ShipTo="Model.ShipTo" Details="Model.Details" Formatter="_formatter" />
    <InvoiceItemsTable Items="Model.Items" Formatter="_formatter" />
    <InvoiceSummarySection
        CustomerMessageTitle="Model.CustomerMessageTitle"
        CustomerMessage="Model.CustomerMessage"
        Subtotal="Subtotal"
        SalesTax="SalesTax"
        Shipping="Shipping"
        Total="Total"
        Formatter="_formatter" />
</article>

@code {
    [Parameter]
    public required InvoiceDocumentModel Model { get; set; }

    private InvoiceDisplayFormatter _formatter = new("en-US", "USD");

    private decimal Subtotal => InvoiceCalculations.GetSubtotal(Model);

    private decimal SalesTax => InvoiceCalculations.GetSalesTax(Model, Subtotal);

    private decimal Shipping => InvoiceCalculations.GetShipping(Model);

    private decimal Total => InvoiceCalculations.GetTotal(Model, Subtotal, SalesTax, Shipping);

    protected override void OnParametersSet()
    {
        _formatter = new InvoiceDisplayFormatter(Model.Locale, Model.CurrencyCode);
    }
}
