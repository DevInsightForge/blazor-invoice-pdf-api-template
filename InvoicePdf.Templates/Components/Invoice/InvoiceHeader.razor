@using InvoicePdf.Templates.Models
@using InvoicePdf.Templates.Utilities

<header class="invoice-header">
    <section>
        @if (!string.IsNullOrWhiteSpace(Company.LogoUrl))
        {
            <div class="logo-box">
                <img src="@Company.LogoUrl" alt="Company logo" />
            </div>
        }
        else
        {
            <div class="logo-box">
                <BrandLogo />
            </div>
        }
        <p class="company-name">@Formatter.SafeText(Company.CompanyName)</p>
        <p class="company-lines">@Formatter.FormatAddress(Company.Address)</p>
    </section>

    <section>
        <p class="contact-lines">@BuildCompanyContacts()</p>
    </section>

    <h1 class="invoice-title">@Formatter.SafeText(Details.Title)</h1>
</header>

@code {
    [Parameter]
    public required CompanyInfoModel Company { get; set; }

    [Parameter]
    public required InvoiceDetailsModel Details { get; set; }

    [Parameter]
    public required InvoiceDisplayFormatter Formatter { get; set; }

    private string BuildCompanyContacts()
    {
        var parts = new List<string>();

        if (!string.IsNullOrWhiteSpace(Company.Phone))
        {
            parts.Add(Company.Phone);
        }

        if (!string.IsNullOrWhiteSpace(Company.Email))
        {
            parts.Add(Company.Email);
        }

        if (!string.IsNullOrWhiteSpace(Company.Website))
        {
            parts.Add(Company.Website);
        }

        return parts.Count == 0 ? "-" : string.Join("\n", parts);
    }
}
