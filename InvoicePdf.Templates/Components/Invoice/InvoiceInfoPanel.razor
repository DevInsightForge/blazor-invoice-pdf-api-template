@using InvoicePdf.Templates.Models
@using InvoicePdf.Templates.Utilities

<section class="address-grid">
    <div class="address-card">
        <p class="card-label">@Formatter.SafeText(BillTo.CardLabel)</p>
        <h2>@Formatter.SafeText(BillTo.Name)</h2>
        @if (!string.IsNullOrWhiteSpace(BillTo.Attention))
        {
            <p>@BillTo.Attention</p>
        }
        <p>@Formatter.SafeText(BillTo.AddressLine1)</p>
        @if (!string.IsNullOrWhiteSpace(BillTo.AddressLine2))
        {
            <p>@BillTo.AddressLine2</p>
        }
        <p>@Formatter.SafeText(BillTo.CityStatePostalCountry)</p>
        @if (!string.IsNullOrWhiteSpace(BillTo.Email))
        {
            <p>@BillTo.Email</p>
        }
    </div>

    <div class="address-card">
        <p class="card-label">@Formatter.SafeText(OrderDetails.CardLabel)</p>
        <h2>@Formatter.SafeText(OrderDetails.Name)</h2>
        @foreach (var row in OrderDetails.Lines)
        {
            <p>@Formatter.SafeText(row.Label): @Formatter.SafeText(row.Value)</p>
        }
    </div>
</section>

@code {
    [Parameter]
    public required BillToInfoModel BillTo { get; set; }

    [Parameter]
    public required OrderDetailsModel OrderDetails { get; set; }

    [Parameter]
    public required InvoiceDisplayFormatter Formatter { get; set; }
}
