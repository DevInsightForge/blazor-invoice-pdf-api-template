@using InvoicePdf.Templates.Models
@using InvoicePdf.Templates.Utilities

<header class="invoice-header">
    <div class="brand-block">
        <p class="eyebrow">@Formatter.SafeText(Company.Eyebrow)</p>
        <h1>@Formatter.SafeText(Company.CompanyName)</h1>
        <p class="brand-meta">@Formatter.SafeText(Company.AddressLine)</p>
        <p class="brand-meta">@BuildContactLine()</p>
    </div>

    <div class="invoice-meta">
        <div class="meta-grid">
            <div class="meta-item">
                <span class="meta-label">Invoice Number</span>
                <strong class="meta-value">@Formatter.SafeText(Invoice.InvoiceNumber)</strong>
            </div>
            <div class="meta-item">
                <span class="meta-label">Issue Date</span>
                <strong class="meta-value">@Formatter.FormatDate(Invoice.IssueDate)</strong>
            </div>
            <div class="meta-item">
                <span class="meta-label">Payment Status</span>
                <strong class="meta-value">@Formatter.SafeText(Invoice.PaymentStatus)</strong>
            </div>
        </div>
    </div>
</header>

@code {
    [Parameter]
    public required CompanyInfoModel Company { get; set; }

    [Parameter]
    public required InvoiceMetaModel Invoice { get; set; }

    [Parameter]
    public required InvoiceDisplayFormatter Formatter { get; set; }

    private string BuildContactLine()
    {
        return $"{Formatter.SafeText(Company.Email)} · {Formatter.SafeText(Company.Phone)}";
    }
}
